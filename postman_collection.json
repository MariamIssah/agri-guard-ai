{
  "info": {
    "_postman_id": "agri-guard-ai-collection",
    "name": "Agri-Guard AI API",
    "description": "Collection for testing Agri-Guard AI ML prediction API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Verify API is running"
      },
      "response": []
    },
    {
      "name": "Get Model Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/model/info",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "model", "info"]
        },
        "description": "Get model architecture and performance info"
      },
      "response": []
    },
    {
      "name": "Get Supported Features",
      "request": {
        "method": "GET",
